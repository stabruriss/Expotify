{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Expotify",
  "version": "0.2.0",
  "identifier": "com.expotify.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Expotify",
        "width": 360,
        "height": 480,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "",
        "url": "overlay.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "width": 420,
        "height": 268,
        "minWidth": 300,
        "minHeight": 180,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Spotify track info with AI insights",
    "longDescription": "Display current Spotify track information with AI-generated insights in a floating window"
  }
}
